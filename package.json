{
  "name": "design-system-metrics",
  "version": "2.6.0",
  "description": "Design system migration reporting for MetaMask",
  "private": true,
  "packageManager": "yarn@4.3.1",
  "scripts": {
    "start": "node index.js --project extension",
    "start:mobile": "node index.js --project mobile",
    "test": "jest",
    "test:watch": "jest --watch",
    "setup-repos": "git submodule update --init --recursive",
    "update-repos": "git submodule update --remote --merge",
    "sync-config": "node scripts/sync-config.js",
    "sync-config:dry-run": "node scripts/sync-config.js --dry-run",
    "sync-config:skip-update": "node scripts/sync-config.js --skip-update",
    "update-timeline": "node scripts/update-timeline.js",
    "validate-metrics": "node scripts/validate-metrics-consistency.js",
    "collect-history": "node scripts/collect-historical-metrics.js",
    "audit-component-props": "node scripts/component-props-audit.js",
    "discover": "node scripts/discover-untracked.js",
    "discover:extension": "node scripts/discover-untracked.js --project extension",
    "discover:mobile": "node scripts/discover-untracked.js --project mobile"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.25.7",
    "@babel/traverse": "^7.25.7",
    "brace-expansion": "^5.0.5",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
